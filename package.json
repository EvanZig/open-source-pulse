{
  "name": "open-source-pulse",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Explorer dashboard that tracks popular repositories for Good First Issues and Help Wanted tags.",
  "scripts": {
    "dev": "xdg-open http://localhost:3000 & next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.8.1",
